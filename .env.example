# ============================================================================
# AI Curation Platform - Environment Configuration
# ============================================================================
#
# SETUP (run once):
#
#   make setup
#
# This copies .env.example to ~/.agr_ai_curation/.env with secure permissions
# and repairs local Langfuse-critical values for the standard make workflow.
#
# MANUAL SETUP:
#
#   mkdir -p ~/.agr_ai_curation
#   cp .env.example ~/.agr_ai_curation/.env
#   chmod 600 ~/.agr_ai_curation/.env
#   ./scripts/utilities/ensure_local_langfuse_env.sh ~/.agr_ai_curation/.env
#
# USAGE:
#
#   make dev          # Start all services
#   make help         # Show all commands
#
# WHY ~/.agr_ai_curation/?
#
#   Keeping secrets outside the repository prevents accidental commits.
#   The Makefile sources this file and passes variables to Docker.
#
# ============================================================================

# ====================
# API Keys
# ====================

# OpenAI API Key for embeddings and GPT-5/GPT-5-mini
OPENAI_API_KEY=your_openai_api_key_here

# Optional OpenAI-compatible base URL override
# OPENAI_BASE_URL=https://api.openai.com/v1
# Optional WebSocket endpoint override; normally leave unset for api.openai.com.
# OPENAI_WEBSOCKET_BASE_URL=wss://api.openai.com/v1

# Gemini API Key (required if LLM_PROVIDER=gemini)
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API key for Groq-backed chat/model execution
GROQ_API_KEY=your_groq_api_key_here

# Optional Groq base URL override
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# Groq tool-calling safety defaults (provider-specific; OpenAI/Gemini unaffected):
# - Keep tool calling deterministic/stable by constraining temperature
# - Default to serial tool calls for Groq (enable only if you explicitly want parallel)
GROQ_TOOL_TEMPERATURE_MAX=0.0
GROQ_PARALLEL_TOOL_CALLS_ENABLED=false
# Retry malformed Groq tool-call JSON failures with capped retries/backoff
GROQ_TOOL_CALL_MAX_RETRIES=2
GROQ_TOOL_CALL_RETRY_DELAY_SECONDS=1.0

# Anthropic API key for Agent Studio chat/suggestion endpoints (optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional explicit model override for Agent Studio chat/suggestion endpoints
PROMPT_EXPLORER_MODEL_ID=claude-opus-4-8
# Legacy override (deprecated; use PROMPT_EXPLORER_MODEL_ID instead)
# ANTHROPIC_OPUS_MODEL=claude-opus-4-8

# Enforce provider/model validation at startup (recommended true in production)
LLM_PROVIDER_STRICT_MODE=true

# Test-only API key bypass (used by automation + contract/integration suites)
TESTING_API_KEY=

# Enable SNS alerts for tool failures (uses PROMPT_SUGGESTIONS_SNS_TOPIC_ARN)
TOOL_FAILURE_ALERTS_ENABLED=false

# LangFuse Configuration (optional - for observability)
# Self-hosted Langfuse instance
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_HOST=http://your-langfuse-host:3000
# Optional: keep Langfuse on a separate database to avoid schema collisions
LANGFUSE_DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/postgres

# Local docker-compose Langfuse defaults.
# These names are what the local stack consumes directly so stale legacy
# LANGFUSE_DATABASE_URL / ENCRYPTION_KEY values cannot break localhost:3000.
LANGFUSE_LOCAL_DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/postgres
LANGFUSE_LOCAL_NEXTAUTH_SECRET=generated-by-make-setup-or-env-repair
LANGFUSE_LOCAL_SALT=generated-by-make-setup-or-env-repair
LANGFUSE_LOCAL_ENCRYPTION_KEY=generated-by-make-setup-or-env-repair
LANGFUSE_LOCAL_PUBLIC_KEY=generated-by-make-setup-or-env-repair
LANGFUSE_LOCAL_SECRET_KEY=generated-by-make-setup-or-env-repair

# Sentry application error reporting (optional; disabled when SENTRY_DSN is blank)
# DSNs can submit events to the project, so keep real values in ignored .env files
# or AWS Secrets Manager. Default blank.
SENTRY_DSN=
# Environment tag attached to Sentry events. Default local.
SENTRY_ENVIRONMENT=local
# Release tag attached to Sentry events; leave blank to omit until release/deploy
# metadata is available. Default blank.
SENTRY_RELEASE=
# Refuse raw http:// DSNs by default. Set true only for sanitized synthetic dev
# tests or private/VPC-only transport while TLS is being added. Default false.
SENTRY_ALLOW_INSECURE_DSN=false
# Enable dev-only synthetic Sentry smoke endpoints. Requires DEV_MODE=true too;
# leave false outside tightly scoped dev smoke testing. Default false.
SENTRY_SYNTHETIC_TEST_ENDPOINTS_ENABLED=false

# ====================
# Weaviate Configuration
# ====================

# Weaviate connection settings
WEAVIATE_HOST=weaviate  # or localhost for local development
WEAVIATE_PORT=8080

# Retrieval reranking
#   none           - Safe default for local Docker unless AWS credentials are mounted
#   bedrock_cohere - Use Amazon Bedrock Cohere Rerank 3.5 after Weaviate retrieval
RERANK_PROVIDER=none
BEDROCK_RERANK_MODEL_ARN=arn:aws:bedrock:us-east-1::foundation-model/cohere.rerank-v3-5:0

# AWS credentials for local/home development:
# - EC2 deployments should use the instance role and should not set static keys.
# - Local docker users should set RERANK_PROVIDER=bedrock_cohere and mount a
#   dedicated least-privilege AWS profile directory into the backend container.
# - The credentials directory should contain AWS CLI-compatible `credentials`
#   and `config` files. Do not commit that directory.
# - RERANK_AWS_PROFILE is consumed only by the Bedrock reranker so host/VM
#   tooling can keep using AWS_PROFILE for broader maintenance credentials.
#RERANK_AWS_PROFILE=ai-curation-rerank-local
#RERANK_AWS_CREDENTIALS_MOUNT_DIR=/home/ctabone/.symphony/secrets/agr_ai_curation/aws-rerank
#RERANK_AWS_SHARED_CREDENTIALS_FILE=/runtime/secrets/aws-rerank/credentials
#RERANK_AWS_CONFIG_FILE=/runtime/secrets/aws-rerank/config
#AWS_REGION=us-east-1
WEAVIATE_SCHEME=http  # http or https

# ====================
# Isolated Test Stack Configuration (optional)
# ====================
# Used by docker-compose.test.yml and scripts/testing/prepare-test-stack.sh

# Optional preferred host-mapped ports for local host (.venv) test execution.
# If omitted, prepare-test-stack will prefer these values when free and otherwise
# let Docker choose safe open ports automatically.
TEST_DB_PORT_HOST=15434
TEST_WEAVIATE_PORT_HOST=18080
TEST_WEAVIATE_GRPC_PORT_HOST=15051

# In-stack test DB credentials (container-to-container)
TEST_DB_USER=postgres
TEST_DB_PASSWORD=postgres
TEST_DB_NAME=ai_curation

# ====================
# PDF Processing Configuration
# ====================

# PDF extraction service URL for document parsing (required for document upload)
# Expected contract root: <url>/api/v1/extract, <url>/api/v1/extract/{process_id}
# For standalone installs where the service runs on the same host, use
# host.docker.internal (not localhost) so the backend container can reach it.
PDF_EXTRACTION_SERVICE_URL=http://host.docker.internal:5000

# PDF extraction processing timeout in seconds (increase for large documents)
PDF_EXTRACTION_TIMEOUT=3600

# Document-processing progress stream timeout (defaults to PDF_EXTRACTION_TIMEOUT when unset)
PDF_PROCESSING_SSE_TIMEOUT_SECONDS=

# Document-processing progress stream poll interval in seconds
PDF_PROCESSING_SSE_POLL_INTERVAL_SECONDS=1

# Optional poll interval in seconds while waiting for extraction status
PDF_EXTRACTION_POLL_INTERVAL_SECONDS=2

# Optional retry window in seconds for transient merged/artifact download errors
PDF_EXTRACTION_DOWNLOAD_RETRY_SECONDS=120

# Optional extraction methods submitted to the service (comma-separated)
PDF_EXTRACTION_METHODS=grobid,marker

# Whether to request merged output from the extraction service.
# Set to false to consume method-specific output (see PRIMARY_DOWNLOAD_METHOD).
PDF_EXTRACTION_MERGE=true

# Optional method name to download when PDF_EXTRACTION_MERGE=false.
# Must match one of PDF_EXTRACTION_METHODS (e.g., grobid | marker).
PDF_EXTRACTION_PRIMARY_DOWNLOAD_METHOD=

# Optional service auth mode for extraction API calls:
#   none | static_bearer | cognito_client_credentials
PDF_EXTRACTION_AUTH_MODE=none

# Required when PDF_EXTRACTION_AUTH_MODE=static_bearer
PDF_EXTRACTION_BEARER_TOKEN=

# Required when PDF_EXTRACTION_AUTH_MODE=cognito_client_credentials
PDF_EXTRACTION_COGNITO_TOKEN_URL=
PDF_EXTRACTION_COGNITO_CLIENT_ID=
PDF_EXTRACTION_COGNITO_CLIENT_SECRET=
PDF_EXTRACTION_COGNITO_SCOPE=

# Optional ABC Literature document-source integration.
# local_pdf keeps the existing upload/extraction flow as the default. Set
# DOCUMENT_SOURCE_PROVIDER=abc_literature and enable DOCUMENT_SOURCE_IMPORT_ENABLED
# in the Operational limits feature-flag section only when external provider
# lookup, download, and constrained existing-reference conversion are enabled
# for the stack.
DOCUMENT_SOURCE_PROVIDER=local_pdf

# ABC Literature REST API base URL. Required only when ABC Literature import is enabled.
ABC_LITERATURE_API_BASE_URL=

# ABC Literature auth mode:
#   none | static_bearer | cognito_client_credentials
ABC_LITERATURE_AUTH_MODE=none

# Required when ABC_LITERATURE_AUTH_MODE=static_bearer
ABC_LITERATURE_BEARER_TOKEN=

# Required when ABC_LITERATURE_AUTH_MODE=cognito_client_credentials
ABC_LITERATURE_COGNITO_TOKEN_URL=
ABC_LITERATURE_COGNITO_CLIENT_ID=
ABC_LITERATURE_COGNITO_CLIENT_SECRET=
ABC_LITERATURE_COGNITO_SCOPE=

# Host-side ABC Literature live smoke runner. Used by
# scripts/testing/abc_literature_live_smoke.py for gated release evidence only;
# these values are not consumed by the backend container.
ABC_LITERATURE_SMOKE_AWS_PROFILE=ctabone
ABC_LITERATURE_SMOKE_AWS_REGION=us-east-1
ABC_LITERATURE_SMOKE_USER_POOL_ID=us-east-1_d3eK6SYpI
ABC_LITERATURE_SMOKE_CLIENT_ID=
ABC_LITERATURE_SMOKE_CLIENT_SECRET=
ABC_LITERATURE_SMOKE_BASE_URL=https://stage-literature-rest.alliancegenome.org
ABC_LITERATURE_SMOKE_AUTHORIZED_GROUPS=FBStaff,FlyBaseCurator
ABC_LITERATURE_SMOKE_EVIDENCE_DIR=file_outputs/temp
ABC_LITERATURE_SMOKE_UNKNOWN_MD5=
ABC_LITERATURE_SMOKE_KNOWN_MD5=
ABC_LITERATURE_SMOKE_RESTRICTED_MD5=
ABC_LITERATURE_SMOKE_PMID=23970418
ABC_LITERATURE_SMOKE_REFERENCE=AGRKB:101000000055784
ABC_LITERATURE_SMOKE_SOURCE_REFERENCEFILE_ID=4040596
ABC_LITERATURE_SMOKE_CONVERTED_REFERENCEFILE_ID=4672234

# Host-side ABC Literature READY upload smoke runner. Used by
# scripts/testing/abc_literature_ready_upload_smoke.py to verify that this AI
# Curation backend can accept the known source PDF, select the ABC READY import,
# ingest provider Markdown, expose text-only downloads/chunks, and clean up.
# The runner uses an existing test curator. Do not create one-off Cognito users
# for this smoke; put the test curator credentials in the local, uncommitted
# .env or provide a short-lived IdToken for manual runs.
# Cognito/AWS/Literature fixture values inherit from ABC_LITERATURE_SMOKE_*
# unless these READY_UPLOAD overrides are set.
ABC_LITERATURE_READY_UPLOAD_SMOKE_BACKEND_BASE_URL=http://localhost:8000
ABC_LITERATURE_READY_UPLOAD_SMOKE_LITERATURE_BASE_URL=https://stage-literature-rest.alliancegenome.org
ABC_LITERATURE_READY_UPLOAD_SMOKE_ENV_FILE=${HOME}/.agr_ai_curation/.env
ABC_LITERATURE_READY_UPLOAD_SMOKE_AWS_PROFILE=ctabone
ABC_LITERATURE_READY_UPLOAD_SMOKE_AWS_DIR=${HOME}/.aws
ABC_LITERATURE_READY_UPLOAD_SMOKE_COMPOSE_FILE=docker-compose.yml
ABC_LITERATURE_READY_UPLOAD_SMOKE_BACKEND_SERVICE=backend
ABC_LITERATURE_READY_UPLOAD_SMOKE_DOCKER_SERVICE=backend
ABC_LITERATURE_READY_UPLOAD_SMOKE_DOCKER_BACKEND_BASE_URL=http://backend:8000
# Optional. Defaults to the host UID:GID running the wrapper, which keeps
# persisted evidence files writable by the checkout owner.
ABC_LITERATURE_READY_UPLOAD_SMOKE_DOCKER_USER=
ABC_LITERATURE_READY_UPLOAD_SMOKE_AWS_REGION=us-east-1
ABC_LITERATURE_READY_UPLOAD_SMOKE_USER_POOL_ID=us-east-1_d3eK6SYpI
ABC_LITERATURE_READY_UPLOAD_SMOKE_CLIENT_ID=
ABC_LITERATURE_READY_UPLOAD_SMOKE_CLIENT_SECRET=
ABC_LITERATURE_READY_UPLOAD_SMOKE_AUTHORIZED_GROUPS=FBStaff,FlyBaseCurator
ABC_LITERATURE_READY_UPLOAD_SMOKE_CURATOR_USERNAME=
ABC_LITERATURE_READY_UPLOAD_SMOKE_CURATOR_PASSWORD=
ABC_LITERATURE_READY_UPLOAD_SMOKE_CURATOR_ID_TOKEN=
ABC_LITERATURE_READY_UPLOAD_SMOKE_EVIDENCE_DIR=file_outputs/temp
ABC_LITERATURE_READY_UPLOAD_SMOKE_KNOWN_MD5=
ABC_LITERATURE_READY_UPLOAD_SMOKE_PMID=23970418
ABC_LITERATURE_READY_UPLOAD_SMOKE_REFERENCE=AGRKB:101000000055784
ABC_LITERATURE_READY_UPLOAD_SMOKE_SOURCE_REFERENCEFILE_ID=4040596
ABC_LITERATURE_READY_UPLOAD_SMOKE_CONVERTED_REFERENCEFILE_ID=4672234
ABC_LITERATURE_READY_UPLOAD_SMOKE_SOURCE_PDF_FILENAME=abc-literature-ready-smoke-23970418.pdf

# Host-side Add Literature manual upload smoke runner. Used by
# scripts/testing/add_literature_upload_smoke.py to verify that an existing fake
# Cognito curator can upload a repo fixture PDF through the Add Literature/manual
# upload path, observe durable PDF job visibility, retrieve chunks/downloads, and
# clean up. Cognito/AWS defaults inherit from ABC_LITERATURE_READY_UPLOAD_SMOKE_*
# unless these overrides are set.
ADD_LITERATURE_UPLOAD_SMOKE_BACKEND_BASE_URL=http://localhost:8000
ADD_LITERATURE_UPLOAD_SMOKE_ENV_FILE=${HOME}/.agr_ai_curation/.env
ADD_LITERATURE_UPLOAD_SMOKE_AWS_PROFILE=ctabone
ADD_LITERATURE_UPLOAD_SMOKE_AWS_REGION=us-east-1
ADD_LITERATURE_UPLOAD_SMOKE_USER_POOL_ID=us-east-1_d3eK6SYpI
ADD_LITERATURE_UPLOAD_SMOKE_CLIENT_ID=
ADD_LITERATURE_UPLOAD_SMOKE_CLIENT_SECRET=
ADD_LITERATURE_UPLOAD_SMOKE_AUTHORIZED_GROUPS=FBStaff,FlyBaseCurator
ADD_LITERATURE_UPLOAD_SMOKE_CURATOR_USERNAME=
ADD_LITERATURE_UPLOAD_SMOKE_CURATOR_PASSWORD=
ADD_LITERATURE_UPLOAD_SMOKE_CURATOR_ID_TOKEN=
ADD_LITERATURE_UPLOAD_SMOKE_EVIDENCE_DIR=file_outputs/temp
ADD_LITERATURE_UPLOAD_SMOKE_SAMPLE_PDF=backend/tests/fixtures/sample_fly_publication.pdf

# PDF extraction strategy - Controls accuracy vs speed trade-off
# Options: fast (fastest, may miss complex layouts)
#          auto (balanced speed/accuracy)
#          hi_res (best accuracy, slowest)
PDF_EXTRACTION_STRATEGY=fast

# Enable table structure inference
# Note: Enabling this will slow down processing significantly
ENABLE_TABLE_EXTRACTION=false

# ====================
# Processing Configuration
# ====================

# Maximum chunk size in tokens for text splitting
MAX_CHUNK_SIZE=1000

# Overlap between chunks in tokens
CHUNK_OVERLAP=100

# ====================
# Logging Configuration
# ====================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log details of failed chunk insertions for debugging
LOG_FAILED_CHUNKS=true

# Log output format:
#   json   - Structured JSON (default, required for GELF/Kibana)
#   simple - Human-readable (for local terminal viewing)
LOG_FORMAT=json

# GELF Centralized Logging (production/dev EC2 only)
# These are used by docker-compose.prod.yml to configure the Docker GELF driver.
# On local/home development, these are ignored (Loki/Promtail is used instead).
#
# Prerequisite: Log-Access-Group (sg-0451f962e9b18aefa) must be attached to EC2 instance.
# See LOGGING_OVERHAUL_AWS_COMMANDS.md for setup instructions.
GELF_HOST=logs.alliancegenome.org
GELF_PORT=12201

# Environment label for log filtering in Kibana ("production" or "dev")
# Set to "dev" on dev EC2, "production" on production EC2. Ignored on local.
LOG_ENV=production

# ====================
# Performance Configuration
# ====================

# Batch size for Weaviate operations
WEAVIATE_BATCH_SIZE=100

# Maximum concurrent workers for processing
MAX_WORKERS=4

# Request timeout in seconds
REQUEST_TIMEOUT=300

# ====================
# Feature Flags
# ====================

# Enable fail-fast behavior (recommended for production)
FAIL_FAST=true

# Enable deterministic UUID generation for idempotent operations
DETERMINISTIC_UUIDS=true

# ====================
# Health Check Configuration
# ====================

# Enforce required service health at startup
# When true (default), startup fails if services marked required: true in
# connections.yaml are unhealthy. Set to false for development/testing
# with partial infrastructure.
# IMPORTANT: Keep this true in production!
HEALTH_CHECK_STRICT_MODE=true

# ====================
# Docker Service Credentials
# ====================
# These are used by docker-compose.yml for local services.
# IMPORTANT: Change these from the defaults for any non-local deployment!

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=ai_curation

# Redis (for Langfuse and cross-worker state)
REDIS_AUTH=your_redis_password_here

# ClickHouse (for Langfuse analytics)
CLICKHOUSE_PASSWORD=your_clickhouse_password_here

# MinIO (for Langfuse object storage)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=your_minio_password_here

# ====================
# Database Configuration
# ====================

# Application Database (PostgreSQL)
# Stores: users, pdf_documents, feedback_reports, curation_flows, audit_log, etc.
#
# For Docker deployments: Uses POSTGRES_PASSWORD variable defined above
# For non-Docker deployments: Set the full URL with credentials
#   Format: postgresql://[user]:[pass]@[host]:[port]/[dbname]
#
# Note: config/connections.yaml uses this for health checks. If DATABASE_URL
# is not set, it falls back to a default that may not work outside Docker.
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/ai_curation

# Startup safety controls (default-safe for shared/prod compose usage):
# Keep these false in production. Symphony Human Review Prep can set them true
# for isolated issue workspaces when bootstrap/migrations are needed.
RUN_DB_BOOTSTRAP_ON_START=false
RUN_DB_MIGRATIONS_ON_START=false

# External curation database URL (read-only access via SSH tunnel)
# CURATION_DB_URL=postgresql://<user>:<pass>@host.docker.internal:<tunnel_port>/curation

# Literature reference search uses the agr-curation-api-client Elasticsearch
# helpers rather than a direct literature Postgres tunnel. The endpoint is only
# reachable from the AGR VPC/VPN or equivalent Symphony/Incus environment.
ELASTICSEARCH_HOST=vpc-literature-search-3ioqj2ykpx2jbthmp5ocnbs7vi.us-east-1.es.amazonaws.com
ELASTICSEARCH_PORT=443
ELASTICSEARCH_INDEX=references_index

# Curation Database Credentials Configuration
# Controls how credentials are resolved for the curation database.
# The resolver checks in order: CURATION_DB_URL env → credentials config
#
# CURATION_DB_CREDENTIALS_SOURCE: how to obtain credentials when CURATION_DB_URL is not set
#   env          - Use CURATION_DB_URL from environment (explicit)
#   aws_secrets  - Fetch from AWS Secrets Manager (requires AWS access)
#   url          - Use the URL directly from config/connections.yaml
#CURATION_DB_CREDENTIALS_SOURCE=env

# AWS Secrets Manager secret ID for curation DB credentials
# Used when CURATION_DB_CREDENTIALS_SOURCE=aws_secrets
#CURATION_DB_AWS_SECRET_ID=ai-curation/db/curation-readonly

# ====================
# Feedback System SMTP Configuration
# ====================

# SMTP server for sending feedback notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# SMTP authentication credentials
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password

# Email sender information
EMAIL_FROM_ADDRESS=your_email@gmail.com
EMAIL_FROM_NAME=AI Curation Feedback System

# Email recipient(s) for feedback notifications
# Can be a single email or comma-separated list
FEEDBACK_RECIPIENT_EMAIL=developer@example.com

# ====================
# Authentication Configuration
# ====================
# AUTH_PROVIDER selects which authentication backend to use:
#   cognito  - AWS Cognito
#   oidc     - Generic OIDC provider (Keycloak, Auth0, Okta, etc.)
#   dev      - Development mode (bypasses auth, requires DEV_MODE=true)
# Required. Must be set explicitly; there is no runtime default.
AUTH_PROVIDER=

# --- Development auth identity (used only with AUTH_PROVIDER=dev / DEV_MODE=true) ---
# Optional display identity for local/dev auth bypass. Useful for previewing a
# curator's group-specific UI without changing real identity-provider accounts.
DEV_USER_SUB=dev-user-123
DEV_USER_EMAIL=dev@localhost
DEV_USER_NAME=Dev User
DEV_USER_GROUPS=

# Frontend dev-mode identity shown when VITE_DEV_MODE=true.
VITE_DEV_USER_SUB=dev-user-123
VITE_DEV_USER_EMAIL=dev@localhost
VITE_DEV_USER_NAME=Dev User
VITE_DEV_USER_GROUPS=

# --- AWS Cognito Settings (used when AUTH_PROVIDER=cognito) ---

# AWS Cognito Region
# Example: us-east-1
COGNITO_REGION=us-east-1

# Cognito User Pool ID
# Example: us-east-1_XXXXXXXXX
COGNITO_USER_POOL_ID=your_user_pool_id_here

# Cognito Application Client ID
COGNITO_CLIENT_ID=your_client_id_here

# Cognito Application Client Secret
COGNITO_CLIENT_SECRET=your_client_secret_here

# Cognito Custom Domain (for Hosted UI)
# This is the domain where Cognito's Hosted UI is hosted
# Default: https://auth.alliancegenome.org
COGNITO_DOMAIN=https://auth.alliancegenome.org

# Cognito Redirect URI (for OAuth callback)
# Default for local development: http://localhost:3002/auth/callback
# Production: https://your-domain.com/auth/callback
COGNITO_REDIRECT_URI=http://localhost:3002/auth/callback

# --- Generic OIDC Settings (used when AUTH_PROVIDER=oidc) ---
# Required for OIDC: OIDC_ISSUER_URL, OIDC_CLIENT_ID, and OIDC_REDIRECT_URI

# OIDC Issuer URL (the provider's base URL for discovery)
# Examples:
#   Keycloak: https://keycloak.example.com/realms/my-realm
#   Auth0:    https://my-tenant.auth0.com
#   Okta:     https://my-org.okta.com/oauth2/default
#OIDC_ISSUER_URL=

# OIDC Client ID (from your identity provider)
#OIDC_CLIENT_ID=

# OIDC Client Secret (optional for public clients, required for confidential clients)
#OIDC_CLIENT_SECRET=

# OIDC Redirect URI (where the provider sends the user after login)
# Required when AUTH_PROVIDER=oidc (no Cognito fallback)
#OIDC_REDIRECT_URI=http://localhost:3002/auth/callback

# OIDC Scopes (space-separated, default: "openid profile email")
#OIDC_SCOPES=openid profile email

# OIDC Group Claim (the JWT claim containing user group memberships)
# Default: reads from config/groups.yaml identity_provider.group_claim
# Examples:
#   Cognito:  cognito:groups
#   Keycloak: realm_access.roles  (dot-path supported)
#   Auth0:    https://my-app.com/roles
#   Okta:     groups
#OIDC_GROUP_CLAIM=groups

# OIDC Logout URL (provider's logout endpoint, discovered automatically if not set)
#OIDC_LOGOUT_URL=

# OIDC logout redirect parameter name (default: post_logout_redirect_uri)
# Use logout_uri for Cognito-compatible custom logout endpoints.
#OIDC_LOGOUT_REDIRECT_PARAM=post_logout_redirect_uri

# --- Session Settings ---

# Session timeout in hours (default: 24 hours)
# Set lower for testing (e.g., 0.01 = 36 seconds)
SESSION_TIMEOUT_HOURS=24

# Secure cookie setting (default: false for local development)
# CRITICAL: Set to true in production to enable HTTPS-only cookies
# When true, cookies will only be sent over HTTPS connections (prevents token interception)
# When false, cookies can be sent over HTTP (for local development only)
SECURE_COOKIES=false

# ====================
# LLM Model Configuration
# ====================

# Embedding model for Vector Store (Weaviate)
# Examples: text-embedding-3-small, text-embedding-3-large
EMBEDDING_MODEL=text-embedding-3-small

# Embedding token preflight safeguards (backend/src/lib/pipeline/store.py)
# Set false to disable preflight and rely on provider-side limit enforcement.
EMBEDDING_TOKEN_PREFLIGHT_ENABLED=true

# Max token context for embedding model (text-embedding-3-small/large = 8191)
EMBEDDING_MODEL_TOKEN_LIMIT=8191

# Safety buffer subtracted from EMBEDDING_MODEL_TOKEN_LIMIT before insert
EMBEDDING_TOKEN_SAFETY_MARGIN=500

# Character length for contentPreview (used for reranking)
CONTENT_PREVIEW_CHARS=1600

# Weaviate batch insert throttle (requests per minute)
WEAVIATE_BATCH_REQUESTS_PER_MINUTE=5000

# ====================
# LLM Provider Configuration
# ====================
# Select which LLM provider to use for all agents.
# Options: openai (default), gemini
#
# When using Gemini, models are accessed via OpenAI compatibility mode.
# The GEMINI_API_KEY must be set when LLM_PROVIDER=gemini.
#
# Supported models by provider:
#   OpenAI: gpt-5.5, gpt-5.4-mini   (gpt-4o is retired - DO NOT USE)
#   Gemini: gemini-3-pro-preview (with "low"/"high" thinking levels)
#
LLM_PROVIDER=openai

# ====================
# Default Agent Settings
# ====================
# These are the master defaults - all agents inherit these unless overridden.
# Change here to switch all agents at once.
#
# SOURCE OF TRUTH: .env is the single source of truth for all model / LLM config.
# There are NO hardcoded model fallbacks in code -- a missing required value fails
# fast (raises) so the misconfiguration gets fixed instead of silently running on
# the wrong model. The only place a model literal default may live is a package
# agent.yaml (model_config). gpt-4o is retired and de-registered; use the
# registered GPT-5 family entries (`gpt-5.4-mini` or `gpt-5.5`). Automated tools
# sometimes default to gpt-4o -- never do that.

# Default model for all agents (REQUIRED; validation agents default to gpt-5.4-mini/high in their package configs)
DEFAULT_AGENT_MODEL=gpt-5.5

# Temperature: Only used by Gemini models. GPT-5 ignores temperature when reasoning is enabled.
# Gemini 3 Pro requires temperature >= 1.0 (LiteLLM warning)
# Uncomment and set when using Gemini:
#DEFAULT_AGENT_TEMPERATURE=1.0

# Reasoning effort: minimal, low, medium, high, xhigh
# - GPT-5: Uses all five levels directly (default: medium per OpenAI)
# - Gemini 3: Maps minimal/low → "low" thinking, medium/high/xhigh → "high" thinking
# Higher = better quality but slower/more expensive
DEFAULT_AGENT_REASONING=low

# Supervisor uses higher reasoning by default (complex routing decisions)
DEFAULT_SUPERVISOR_REASONING=medium

# Evidence quote confirmation uses exact verification first, then bounded fuzzy
# candidates with a low-context LLM arbiter only when needed.
EVIDENCE_CONFIRMATION_ENABLED=true
EVIDENCE_CONFIRMATION_MODEL=gpt-5-nano
EVIDENCE_CONFIRMATION_TIMEOUT_SECONDS=8

# ====================
# Pipeline / Utility LLM Models (REQUIRED; fail fast if unset)
# ====================
# These models were previously hardcoded as Python fallbacks. They now MUST be
# defined here (.env is the single source of truth; no code fallback).
#
# Section-hierarchy resolution during PDF ingestion:
HIERARCHY_LLM_MODEL=gpt-5.4-mini
HIERARCHY_LLM_REASONING=low
# Abstract-extraction helper:
ABSTRACT_EXTRACTION_MODEL=gpt-5.4-mini

# ====================
# OpenAI Agents Configuration
# ====================
# Each agent can be configured individually via environment variables.
# If not set, agents inherit from DEFAULT_AGENT_* settings above.
#
# Naming convention: AGENT_{AGENT_NAME}_{SETTING}
#
# Available settings per agent:
#   MODEL       - Model name (e.g., gpt-5.4-mini, gemini-3-pro-preview)
#   TEMPERATURE - Temperature (0.0 to 1.0) - only used by Gemini, GPT-5 ignores this
#   REASONING   - Reasoning effort (minimal, low, medium, high, xhigh)
#   TOOL_CHOICE - Tool selection mode (required, auto, or specific tool name)

# --- Global Runner Setting ---
# Base per-run turn budget for the supervisor and (as the base) the specialists.
# Specialists with bulk_list_optimization can adapt higher (up to their package cap).
# 60 gives the gene-expression resolve -> stage -> patch -> finalize loop room to complete.
AGENT_MAX_TURNS=60

# ============================================================================
# Operational limits (turns, batches, caps, timeouts)
# ============================================================================
# Every value below is the historical hardcoded default surfaced here so it is
# discoverable and tunable. Leaving a line commented (or absent) keeps the
# default; behavior is identical to not setting it. Most are wired through
# getters in backend/src/lib/openai_agents/config.py; the ones marked
# "[package]" are read directly from os.environ inside the isolated package
# subprocess (which inherits the backend environment), using the same names.

# --- Frontend browser cache limits ---
# Max assistant-chat messages retained in browser localStorage for current-session
# restore. Lower values reclaim browser quota sooner; higher values preserve a
# longer local transcript snapshot. Server-side chat history is unaffected.
# Default 100.
VITE_AI_CURATION_CHAT_MESSAGE_CACHE_MAX_ENTRIES=100
# Max session-scoped chat audit render caches retained in browser localStorage.
# Lower values reclaim browser quota sooner; higher values preserve more audit
# panel replay state. Server-side chat history and uploaded PDFs are unaffected.
# Default 40.
VITE_AI_CURATION_CHAT_RENDER_CACHE_MAX_ENTRIES=40
# Max batch audit replay caches retained in browser localStorage. Lower values
# reclaim browser quota sooner; higher values preserve more recent batch audit
# replay state. Server-side batch records and result files are unaffected.
# Default 20.
VITE_AI_CURATION_BATCH_AUDIT_CACHE_MAX_ENTRIES=20

# --- OpenAI Responses WebSocket transport ---
# Use OpenAI Responses API WebSocket transport for long-running, tool-heavy
# agent flows. Set to false only as a diagnostic or reliability fallback; false
# forces slower standard HTTP Responses transport. Default true.
OPENAI_RESPONSES_WEBSOCKET_ENABLED=true
# Seconds between WebSocket keepalive pings. Set to 0/none to disable pings.
# Lower values detect dead connections sooner; higher values reduce ping traffic.
# Default 20.
OPENAI_RESPONSES_WEBSOCKET_PING_INTERVAL_SECONDS=20
# Seconds to wait for a WebSocket pong before closing the connection. Set to
# 0/none to disable heartbeat timeouts, which avoids killing long reasoning
# turns while still allowing provider/network hard closes to surface. Default 0.
OPENAI_RESPONSES_WEBSOCKET_PING_TIMEOUT_SECONDS=0

# --- Document source feature flags ---
# Enables external document-source import. Keep false unless the stack has a
# configured non-local DOCUMENT_SOURCE_PROVIDER and the import API/UI are ready;
# false preserves the existing local PDF upload/extraction path. Default false.
DOCUMENT_SOURCE_IMPORT_ENABLED=false
# HTTP timeout for individual Literature calls inside the ABC live smoke pytest
# harness. Lower values fail faster on service/network stalls; higher values
# tolerate slow stage responses during release evidence. Default 20.
ABC_LITERATURE_SMOKE_TIMEOUT_SECONDS=20
# Overall pytest subprocess timeout for the durable ABC Literature live smoke
# runner. Lower values fail stuck smoke runs faster; higher values tolerate slow
# live service checks. Default 180.
ABC_LITERATURE_SMOKE_PYTEST_TIMEOUT_SECONDS=180
# Botocore read timeout for Cognito/STS calls made by the durable ABC Literature
# live smoke runner. Lower values reduce the chance of hanging with temporary
# users mid-cleanup; higher values tolerate slow AWS API responses. Default 30.
ABC_LITERATURE_SMOKE_AWS_API_TIMEOUT_SECONDS=30
# Max stdout/stderr characters stored per pytest evidence tail in the durable
# ABC Literature live smoke. Lower values keep evidence smaller; higher values
# preserve more failure context after secret redaction. Default 4000.
ABC_LITERATURE_SMOKE_EVIDENCE_TAIL_LIMIT=4000
# HTTP timeout for individual backend and Literature calls made by the ABC
# READY upload smoke runner. Lower values fail fast on unavailable stacks;
# higher values tolerate slow local/remote services. Default 30.
ABC_LITERATURE_READY_UPLOAD_SMOKE_HTTP_TIMEOUT_SECONDS=30
# Multipart upload timeout for the ABC READY upload smoke. Lower values catch
# stuck uploads quickly; higher values tolerate slow local backends. Default 180.
ABC_LITERATURE_READY_UPLOAD_SMOKE_UPLOAD_TIMEOUT_SECONDS=180
# Total seconds the ABC READY upload smoke waits for provider Markdown ingestion
# to complete. Lower values fail slow pipelines faster; higher values tolerate
# release-stack load. Default 240.
ABC_LITERATURE_READY_UPLOAD_SMOKE_PROCESSING_TIMEOUT_SECONDS=240
# Poll interval while waiting for ABC READY upload processing completion. Lower
# values provide faster feedback with more backend requests; higher values are
# gentler but slower. Default 2.
ABC_LITERATURE_READY_UPLOAD_SMOKE_POLL_INTERVAL_SECONDS=2
# Botocore read timeout for Cognito/STS calls made by the ABC READY upload smoke
# runner when exchanging the persistent test curator password for an IdToken.
# Lower values fail stuck auth faster; higher values tolerate slow AWS API
# responses. Default 30.
ABC_LITERATURE_READY_UPLOAD_SMOKE_AWS_API_TIMEOUT_SECONDS=30
# Max characters retained from long failure strings in ABC READY upload smoke
# evidence after global secret redaction. Lower values keep evidence smaller;
# higher values preserve more debug context. Default 4000.
ABC_LITERATURE_READY_UPLOAD_SMOKE_EVIDENCE_TAIL_LIMIT=4000
# HTTP timeout for individual backend calls made by the Add Literature manual
# upload smoke. Lower values fail fast on unavailable stacks; higher values
# tolerate slow local/remote services. Default 30.
ADD_LITERATURE_UPLOAD_SMOKE_HTTP_TIMEOUT_SECONDS=30
# Multipart upload timeout for the Add Literature manual upload smoke. Lower
# values catch stuck uploads quickly; higher values tolerate slow backends.
# Default 180.
ADD_LITERATURE_UPLOAD_SMOKE_UPLOAD_TIMEOUT_SECONDS=180
# Total seconds the Add Literature manual upload smoke waits for PDF processing
# to complete. Lower values fail slow pipelines faster; higher values tolerate
# full local PDFX extraction on larger fixture PDFs. Default 600.
ADD_LITERATURE_UPLOAD_SMOKE_PROCESSING_TIMEOUT_SECONDS=600
# Poll interval while waiting for Add Literature PDF processing completion.
# Lower values provide faster feedback with more backend requests; higher values
# are gentler but slower. Default 2.
ADD_LITERATURE_UPLOAD_SMOKE_POLL_INTERVAL_SECONDS=2
# Botocore read timeout for Cognito/STS calls made by the Add Literature manual
# upload smoke when exchanging the persistent fake curator password for an
# IdToken. Lower values fail stuck auth faster; higher values tolerate slow AWS
# API responses. Default 30.
ADD_LITERATURE_UPLOAD_SMOKE_AWS_API_TIMEOUT_SECONDS=30
# Max characters retained from long failure strings in Add Literature manual
# upload smoke evidence after global secret redaction. Lower values keep evidence
# smaller; higher values preserve more debug context. Default 4000.
ADD_LITERATURE_UPLOAD_SMOKE_EVIDENCE_TAIL_LIMIT=4000
# History window, in days, used when asserting durable PDF job visibility after
# Add Literature manual upload. Lower values reduce query scope; higher values
# tolerate delayed/stale local evidence. Default 7.
ADD_LITERATURE_UPLOAD_SMOKE_JOB_LIST_WINDOW_DAYS=7
# Maximum PDF job rows requested when asserting durable job visibility after Add
# Literature manual upload. Lower values reduce response size; higher values
# tolerate busy fake-curator accounts. Default 50.
ADD_LITERATURE_UPLOAD_SMOKE_JOB_LIST_LIMIT=50

# --- Agent / turn limits ---
# Total distinct specialist invocations the chat supervisor may run per turn.
# Backstop for runaway/no-progress loops (per-call dedup is the primary brake).
# Set high so legitimate multi-lookup chats are never truncated. Default 25.
SUPERVISOR_MAX_SPECIALIST_CALLS_PER_TURN=25
# Distinct invocations of any single specialist the supervisor may run per turn.
# Catches a storm against one specialist (e.g. repeated allele lookups) without
# serializing legitimate different-query work. Default 8.
SUPERVISOR_MAX_CALLS_PER_SPECIALIST=8
# Turn budget for single-shot guardrail structured-output agents. These have no
# tools and only emit safety/topic decisions; default 10 matches the Agents SDK
# default they previously inherited while making the bound explicit.
GUARDRAIL_SINGLE_SHOT_MAX_TURNS=10
# Turn budget for the one-shot document hierarchy classifier. The agent has no
# tools and returns structured section metadata; default 10 matches the Agents
# SDK default it previously inherited while making the bound explicit.
HIERARCHY_RESOLUTION_MAX_TURNS=10
# Estimated model-live context budget for standard assistant chat. The
# compaction trigger is derived from this budget and the threshold percent
# below. Raise only after confirming the supervisor model supports a larger
# context; lower to compact long chats sooner. Default 400000.
STANDARD_CHAT_CONTEXT_TOKEN_BUDGET=400000
# Percent of the standard-chat context budget that triggers OpenAI Responses
# compaction. Default 70 means long chats compact at about 70% of the configured
# model-live budget while exact transcript text stays in durable chat history.
STANDARD_CHAT_COMPACTION_THRESHOLD_PERCENT=70

# --- Validator dispatch ---
# Max validator jobs the dispatcher runs concurrently. Higher = more parallel
# LLM/DB load; lower = slower but gentler on provider and database. Default 4.
MAX_PARALLEL_VALIDATORS=8
# Default cap on deduped validator jobs carried in one batch run (used when a
# binding does not set batch_max_size). The batch turn budget scales with the
# number of jobs, so a large cap risks "Max turns exceeded" and unbounded cost.
# Kept small so chunks run in parallel instead of one long serial run. Default 8.
VALIDATOR_BATCH_MAX_SIZE=8
# Per-job tool-call budget for a binding without max_tool_calls. The batch
# max_turns is derived as len(jobs) * this, so a multi-lookup composite validator
# is never starved mid-batch. Default 8.
VALIDATOR_MAX_TOOL_CALLS=8

# --- Structured finalization ---
# Default attempts for the structured-finalization loop (when a finalization
# config does not set max_attempts). More attempts = more chances to emit valid
# structured output at the cost of extra model calls. Default 6.
STRUCTURED_FINALIZATION_MAX_ATTEMPTS=6
# Absolute ceiling on structured-finalization attempts. Configured max_attempts
# values are clamped to this so a misconfiguration cannot drive unbounded
# retries. Default 20.
STRUCTURED_FINALIZATION_HARD_MAX_ATTEMPTS=20
# Turn budget for the simplified output-synthesis retry agent (runs without
# tools/guardrails; just needs to synthesize output, so it is deliberately
# tight). Default 5.
STRUCTURED_FINALIZATION_RETRY_MAX_TURNS=5
# Consecutive same-specialist calls before the supervisor batching nudge fires.
# Lower = nudge toward batching sooner; higher = tolerate more repeated single
# calls. Default 3.
BATCHING_NUDGE_THRESHOLD=3
# Kill-switch for Layer-2 tool-forced structured finalization
# (tool_choice=required + ToolsToFinalOutputFunction). Set to false to fall back
# to the prior Layer-1 structured-finalization loop instantly without a redeploy.
# Default true.
LAYER2_FORCE_TOOL_FINALIZATION_ENABLED=true

# --- Tool list / page / section limits ---
# Default max chunks a section-read tool returns. Higher = more section content
# per read at the cost of larger payloads/context. Honored by BOTH the backend
# and the [package] weaviate_search tools via this single name. Default 30.
SECTION_READ_MAX_CHUNKS=30
# Characters of surrounding context shown either side of a section snippet match.
# Larger = more context per snippet. Honored by BOTH the backend and [package]
# weaviate_search tools. Default 200.
SECTION_SNIPPET_RADIUS_CHARS=200
# Default page size for bounded-list tool pagination when a call omits a limit.
# Default 20.
TOOL_PAGE_DEFAULT_LIMIT=20
# Hard ceiling on bounded-list tool page size regardless of the requested limit
# (bounds payload size). Default 50.
TOOL_PAGE_MAX_LIMIT=50
# Default number of objects shown in extraction-result supervisor manifests and
# inspect_results object pages when no explicit limit is supplied. Higher values
# make normal extraction answers more complete but increase model context. Default 100.
SUPERVISOR_MANIFEST_PAGE_SIZE=100
# Default number of evidence records returned by inspect_results evidence pages
# when no explicit limit is supplied. Higher values expose more quotes per call
# but increase model context. Default 20.
INSPECT_RESULTS_EVIDENCE_PAGE_SIZE=20
# Default number of result summaries returned by inspect_results list pages.
# Higher values show more extraction-result refs per call but increase model
# context. Default 5.
INSPECT_RESULTS_LIST_PAGE_SIZE=5
# Default number of validation findings returned by inspect_results validation
# pages. Higher values show more findings per call but increase model context.
# Default 5.
INSPECT_RESULTS_VALIDATION_PAGE_SIZE=5
# Default cap on records returned by list_recorded_evidence when no explicit
# limit is given. Default 100.
LIST_RECORDED_EVIDENCE_LIMIT=100
# [package] Default page size for builder list tools (agr_curation) when no
# explicit limit is given. Default 50.
BUILDER_LIST_DEFAULT_LIMIT=50
# [package] Default page size for literature reference lookups. Default 20.
LITERATURE_REFERENCE_DEFAULT_LIMIT=20
# [package] Hard-cap page size for literature reference lookups. Default 100.
LITERATURE_REFERENCE_HARD_MAX=100
# Maximum documents accepted by one document-source import request. Higher
# values can make batch imports faster but increase provider/API and local
# processing load per request. Default 10.
DOCUMENT_SOURCE_IMPORT_BATCH_LIMIT=10
# Safety ceiling on the grand total of matched rows a single bulk lookup hands
# back across all of its inputs combined (each per-symbol limit still applies);
# stops a long symbol list returning an unbounded payload. Honored by the backend
# and the [package] subprocess via this one name. Default 500.
BULK_TOTAL_MATCH_CAP=500

# --- Display / truncation ---
# Char limit for short inline text previews surfaced to the supervisor. Default 220.
SUPERVISOR_TEXT_PREVIEW_LIMIT=220
# Per-field char truncation budget when compacting JSON for the supervisor.
# Default 500.
SUPERVISOR_FIELD_TEXT_LIMIT=500
# Per-evidence-text char truncation budget for inspect_results evidence views.
# Default 500.
INSPECT_RESULTS_EVIDENCE_TEXT_LIMIT=500
# Max list items returned inside one inspect_results validation detail value.
# Higher values expose more nested validation payload per finding. Default 5.
INSPECT_RESULTS_VALIDATION_DETAIL_LIST_LIMIT=5
# Max nested JSON depth returned by inspect_results detail views. Higher values
# expose deeper validation/evidence metadata but increase context. Default 6.
INSPECT_RESULTS_JSON_DEPTH_LIMIT=6
# Max mapping keys returned by inspect_results compact JSON views. Higher values
# expose wider nested objects but increase context. Default 25.
INSPECT_RESULTS_JSON_OBJECT_ITEM_LIMIT=25
# Max list page size for supervisor context list tools. Default 20.
SUPERVISOR_MAX_LIST_LIMIT=20
# Default number of exact transcript messages returned by recall_chat_history
# when no explicit limit is supplied. Higher values expose more chat history per
# call but increase model context. Default 5.
SUPERVISOR_RECALL_CHAT_HISTORY_DEFAULT_LIMIT=5
# Default number of trace inventory rows returned by inspect_chat_traces when no
# explicit limit is supplied. Higher values expose more trace candidates per
# call but increase model context. Default 5.
SUPERVISOR_INSPECT_CHAT_TRACES_DEFAULT_LIMIT=5
# Char limit per string when materializing validation detail into findings.
# Default 8000.
VALIDATION_DETAIL_STRING_LIMIT=8000
# Max list items kept when materializing validation detail. Default 25.
VALIDATION_DETAIL_LIST_LIMIT=25
# Max mapping keys kept when materializing validation detail. Default 50.
VALIDATION_DETAIL_MAPPING_LIMIT=50
# Char limit for tool-output previews stored per flow step. Default 800.
FLOW_STEP_OUTPUT_PREVIEW_CHARS=800
# Max evidence records included in a per-flow-step preview. Default 10.
FLOW_STEP_EVIDENCE_PREVIEW_LIMIT=10
# Rows visible formatter/projection tools preview while building/checking a plan.
# Default 5.
FLOW_OUTPUT_PROJECTION_PREVIEW_LIMIT=5
# Extraction-trace event payload preview length (chars). Already-existing env
# var name; kept for compatibility. Clamped to [100, 10000]. Default 1200.
# EXTRACTION_TRACE_EVENT_PREVIEW_LIMIT=1200
# Char size above which an oversized-trace-payload warning is logged
# (diagnostic only). Already-existing env var name. Default 500000.
# EXTRACTION_TRACE_EVENT_SIZE_LOG_THRESHOLD_CHARS=500000

# --- Timeouts / retries ---
# Wall-clock budget (seconds) for one isolated package tool subprocess; on expiry
# the call fails with a timeout error. Higher = tolerate slower tools; lower =
# fail faster. Default 60.
PACKAGE_RUNNER_TIMEOUT_SECONDS=60
# Max retries for transient Groq tool-call JSON parse failures (see Groq section
# above for the companion delay). Default 2.
# GROQ_TOOL_CALL_MAX_RETRIES=2
# Runner-managed retries for transient model-call failures (HTTP 5xx, dropped
# WebSocket). Set to 0 to disable runner-managed retry. Default 3.
OPENAI_MODEL_MAX_RETRIES=3
# Initial delay in seconds for runner-managed model-call retries. Lower retries
# faster after transient transport errors; higher reduces retry pressure.
# Default 0.5.
OPENAI_MODEL_RETRY_INITIAL_DELAY=0.5
# Maximum backoff delay in seconds for runner-managed model-call retries.
# Higher tolerates longer provider/network blips; lower fails faster. Default 8.
OPENAI_MODEL_RETRY_MAX_DELAY=8.0
# Exponential backoff multiplier for runner-managed model-call retries.
# Higher spaces retries out faster. Default 2.
OPENAI_MODEL_RETRY_MULTIPLIER=2.0
# HTTP timeout (seconds) for heavy Agent Studio trace tools (langfuse
# reconstruction/payloads) that fetch large payloads. Default 45.
AGENT_STUDIO_TRACE_TOOL_TIMEOUT_SECONDS=45
# Default HTTP timeout (seconds) for Agent Studio Claude-endpoint calls that do
# not override it. Default 30.
AGENT_STUDIO_ENDPOINT_TIMEOUT_SECONDS=30
# Input-token threshold for Anthropic Agent Studio Opus context editing. When
# live provider context crosses this threshold, Anthropic clears stale tool
# uses/results while durable recall tools remain available. Default 140000
# (~70% of the 200K Opus context budget).
AGENT_STUDIO_OPUS_CONTEXT_EDITING_TRIGGER_TOKENS=140000
# Number of most recent Agent Studio Opus tool uses Anthropic should keep when
# context editing clears stale tool context. Higher preserves more live
# tool-loop continuity; lower saves more tokens. Default 3.
AGENT_STUDIO_OPUS_CONTEXT_EDITING_KEEP_TOOL_USES=3
# Max raw tool-result JSON characters replayed to Agent Studio Opus provider
# continuation. Larger results are replaced with compact summaries and recall
# hints for the model, while the frontend still streams the full result.
# Default 12000.
AGENT_STUDIO_PROVIDER_TOOL_RESULT_INLINE_MAX_CHARS=12000
# HTTP timeout (seconds) for the TraceReview export call used by the Prompt
# Explorer. Default 30.
TRACE_REVIEW_EXPORT_TIMEOUT_SECONDS=30
# Optional Sentry transaction tracing sample rate. Leave blank to fully disable
# tracing, including incoming trace continuation; set 0.0-1.0 only after
# transport/redaction are validated. Default blank.
SENTRY_TRACES_SAMPLE_RATE=
# Optional Sentry profiling sample rate. Leave blank to disable profiling
# entirely; set 0.0-1.0 only after transport/redaction are validated. Default
# blank.
SENTRY_PROFILES_SAMPLE_RATE=
# Timeout (seconds) for the ripgrep subprocess in Agent Studio code search.
# Default 30.
CODEBASE_SEARCH_TIMEOUT_SECONDS=30
# HTTP timeout (seconds) for Loki log queries. Default 10.
LOKI_QUERY_TIMEOUT_SECONDS=10
# HTTP timeout (seconds) for document-source provider calls, including ABC
# Literature lookup/list/download requests. Lower fails faster on provider
# slowness; higher tolerates large artifact downloads. Default 10.
DOCUMENT_SOURCE_REQUEST_TIMEOUT_SECONDS=10
# Poll interval (seconds) for provider-backed document-import status loops.
# Lower is more responsive but creates more API traffic. Default 2.
DOCUMENT_SOURCE_POLL_INTERVAL_SECONDS=2
# Wall-clock timeout (seconds) for one provider-backed import job. Higher
# tolerates slow artifact downloads/processing; lower fails stuck imports
# sooner. Default 300.
DOCUMENT_SOURCE_IMPORT_TIMEOUT_SECONDS=300
# HTTP timeout (seconds) for the local-transformers reranker fallback.
# [package] May load inside the isolated package subprocess; read via os.getenv.
# Default 5.
LOCAL_TRANSFORMERS_RERANK_TIMEOUT_SECONDS=5
# Stale-PDF-job timeout. ALREADY env-configurable: set PDF_JOB_STALE_TIMEOUT_SECONDS
# to override directly, else it falls back to 2x PDF_EXTRACTION_TIMEOUT, else the
# built-in 7200s default (floored at 300s).
# PDF_JOB_STALE_TIMEOUT_SECONDS=7200

# --- Feedback / transcript ---
# Page size when paginating a captured feedback transcript. Default 200.
TRANSCRIPT_PAGE_SIZE=200
# Turns kept at each edge of an inline transcript excerpt (the inline cap is 2x
# this; that derived value is not separately configurable). Default 3.
TRANSCRIPT_EXCERPT_EDGE_TURNS=3
# Char truncation budget per transcript turn. Default 500.
MAX_TRANSCRIPT_TURN_CHARS=500
# Max traces captured in a feedback trace snapshot. Default 5.
FEEDBACK_TRACE_SNAPSHOT_TRACES=5
# Max items per trace in a feedback trace snapshot. Default 20.
FEEDBACK_TRACE_SNAPSHOT_ITEMS=20
# Char truncation budget for a feedback trace preview. Default 500.
FEEDBACK_TRACE_PREVIEW_CHARS=500
# Char truncation budget for a feedback trace error string. Default 300.
FEEDBACK_TRACE_ERROR_CHARS=300

# --- Agent Studio diagnostic tools ---
# Max lines one Agent Studio code-read returns. Default 400.
CODEBASE_READ_MAX_LINES=400
# Max content-search hits returned by Agent Studio code search. Default 100.
CODEBASE_SEARCH_MAX_RESULTS=100
# Max file-list entries returned by Agent Studio code search. Default 200.
CODEBASE_FILE_LIST_MAX_RESULTS=200
# Default page size for domain-envelope diagnostic tool listings. Default 10.
DOMAIN_ENVELOPE_DEFAULT_LIMIT=10
# Max page size for domain-envelope diagnostic tool listings. Default 50.
DOMAIN_ENVELOPE_MAX_LIMIT=50
# Char cap on bounded JSON returned by domain-envelope tools. Default 20000.
DOMAIN_ENVELOPE_MAX_JSON_CHARS=20000
# Char cap on the compact summary JSON in domain-envelope tools. Default 4000.
DOMAIN_ENVELOPE_MAX_SUMMARY_JSON_CHARS=4000
# Max resolver lookup attempts retained per object before truncation. Default 25.
DOMAIN_ENVELOPE_MAX_LOOKUP_ATTEMPTS=25
# Max validator lookup attempts retained before truncation. Default 10.
DOMAIN_ENVELOPE_MAX_VALIDATOR_LOOKUP_ATTEMPTS=10
# Max validator summaries retained before truncation. Default 25.
DOMAIN_ENVELOPE_MAX_VALIDATOR_SUMMARIES=25
# Max field paths enumerated to the model. Default 150.
DOMAIN_ENVELOPE_MAX_FIELD_PATHS=150
# Max distinct values surfaced per domain reference key in Agent Studio. Default 50.
DOMAIN_REFERENCE_MAX_VALUES=50

# --- Chat / session / flow listings ---
# Char cap on flow-memory visible output replayed into conversational memory.
# Default 2500.
FLOW_MEMORY_MAX_VISIBLE_OUTPUT_CHARS=2500
# Recent messages scanned when backfilling a chat title. Default 20.
TITLE_BACKFILL_MESSAGE_LIMIT=20
# Max character length of a generated chat title. Default 80.
CHAT_TITLE_MAX_LENGTH=80
# Max page size for chat session listings. Default 100.
CHAT_SESSION_PAGE_SIZE_MAX=100
# Max page size for chat message listings. Default 200.
CHAT_MESSAGE_PAGE_SIZE_MAX=200
# Max messages scanned for a recent-window chat-history query. Default 5000.
CHAT_RECENT_MESSAGE_SCAN_SIZE_MAX=5000
# Max SSE events kept in memory per active executable run for observer
# reattachment. Higher values preserve more live audit/progress replay after
# navigation; lower values reduce per-run memory use. Default 1000.
EXECUTABLE_RUN_EVENT_REPLAY_LIMIT=1000
# Seconds to retain terminal in-memory executable runs after completion.
# Durable chat/job history remains the long-lived source; this short window lets
# remounted routes replay just-finished terminal events. Default 900.
EXECUTABLE_RUN_RETENTION_SECONDS=900
# Max chars for low-cardinality runtime observability tag values sent to
# Sentry by caught runtime exception reporting. Lower values reduce indexed
# tag payload size; higher values can make grouping tags more descriptive.
# Default 200.
RUNTIME_OBSERVABILITY_TAG_VALUE_MAX_CHARS=200
# Max chars for custom context values sent to Sentry by caught runtime
# exception reporting before the global Sentry redaction hook filters custom
# context strings. Lower values reduce event payload size. Default 500.
RUNTIME_OBSERVABILITY_CONTEXT_VALUE_MAX_CHARS=500
# Default page size for flow listings. Default 50.
FLOW_LIST_PAGE_SIZE_DEFAULT=50

# --- Flow output projection tooling ---
# Hard cap on rows a deterministic flow output projection emits (safety ceiling
# against a runaway table). Default 10000.
FLOW_PROJECTION_MAX_ROWS=10000
# Max rows rendered in a chat-format flow output. Default 50.
FLOW_CHAT_MAX_ROWS=50
# Example values shown per field to formatter/projection tools. Default 3.
FLOW_PROJECTION_MAX_FIELD_EXAMPLES=3
# List items previewed per field to formatter/projection tools. Default 5.
FLOW_PROJECTION_MAX_LIST_ITEMS=5
# Object keys previewed per field to formatter/projection tools. Default 12.
FLOW_PROJECTION_MAX_OBJECT_ITEMS=12
# Max nested JSON/list depth shown in deterministic flow output projection
# previews. Lower values make previews smaller; higher values expose more nested
# structure. Default 4.
FLOW_OUTPUT_PROJECTION_PREVIEW_MAX_DEPTH=4
# Max nested JSON/list depth shown in formatter preview values. Lower values
# make formatter inspection smaller; higher values expose more nested structure.
# Default 4.
FORMATTER_PREVIEW_MAX_DEPTH=4
# Char cap on text fields formatter/projection tools inspect. Default 180.
FLOW_PROJECTION_MAX_TEXT_CHARS=180
# Char cap on row previews formatter/projection tools inspect. Default 2000.
FLOW_PROJECTION_MAX_ROW_CHARS=2000

# --- Curation / pipeline / infra ---
# Candidate count at/above which curation persistence switches to async
# processing (below it, candidates persist synchronously). Default 25.
ASYNC_CANDIDATE_THRESHOLD=25
# Bounded size of a per-batch SSE event queue (prevents unbounded memory growth
# when a consumer is slow). Default 1000.
BATCH_EVENT_QUEUE_MAXSIZE=1000
# Max log lines returned per Loki query. Default 2000.
LOKI_QUERY_LIMIT=2000
# Max source documents sent to the Bedrock reranker in one call (the provider
# also enforces its own ceiling). [package] read via os.getenv. Default 100.
BEDROCK_RERANK_MAX_SOURCES=100
# Ratio at/above which a mostly page-only (low-precision) evidence set is flagged
# as degraded quality. Default 0.5.
EVIDENCE_PAGE_ONLY_DEGRADED_RATIO_THRESHOLD=0.5

# --- File / upload size caps ---
# Max byte size of a generated file output (CSV/TSV/JSON) before storage rejects
# it. Default 104857600 (100 MB).
FILE_OUTPUT_MAX_SIZE_BYTES=104857600
# Max byte size of an uploaded/processed PDF. Default 157286400 (150 MB).
PDF_MAX_FILE_SIZE_BYTES=157286400

# --- Display / truncation limits ---
# Char truncation budget for record_evidence tool text previews. Default 300.
RECORD_EVIDENCE_PREVIEW_CHARS=300
# Min/max chars of stitched context the PDF viewer fuzzy matcher keeps around a
# located quote. Defaults 240 / 1600.
PDF_STITCHED_CONTEXT_MIN_CHARS=240
PDF_STITCHED_CONTEXT_MAX_CHARS=1600

# ====================
# Per-Agent Overrides (optional)
# ====================
# Uncomment to override defaults for specific agents.

