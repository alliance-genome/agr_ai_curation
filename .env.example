# ============================================================================
# Trace Review (Agent Studio) Configuration
# ============================================================================
# Published backend/frontend images used by docker-compose.production.yml.
BACKEND_IMAGE=public.ecr.aws/v4p5b7m9/agr-ai-curation-backend
BACKEND_IMAGE_TAG=latest
FRONTEND_IMAGE=public.ecr.aws/v4p5b7m9/agr-ai-curation-frontend
FRONTEND_IMAGE_TAG=latest

# The main docker-compose stack pulls the published trace_review_backend image
# and connects to it over the shared Compose network.
#
# If you're not using trace_review, you can ignore this section.
# For trace_review setup, you can also use a separate file at:
#   ~/.agr_ai_curation/trace_review/.env
# ============================================================================

# Published trace_review_backend image used by docker-compose.yml
TRACE_REVIEW_BACKEND_IMAGE=public.ecr.aws/v4p5b7m9/agr-ai-curation-trace-review-backend
TRACE_REVIEW_BACKEND_IMAGE_TAG=latest

# Main backend -> trace_review_backend service URL
TRACE_REVIEW_URL=http://trace_review_backend:8001

# Shared durable extraction trace-event JSONL directory mounted by backend and TraceReview.
EXTRACTION_TRACE_EVENT_DIR=/app/extraction_trace_events

# Shared bearer token for main backend -> TraceReview export API calls.
# Required when TRACE_REVIEW_DEV_MODE=false and feedback trace capture uses
# TRACE_CONTEXT_SOURCE=trace_review_export.
TRACE_REVIEW_INTERNAL_API_TOKEN=

# Trace Review - Development Mode
# Set to true for local development without Cognito auth
TRACE_REVIEW_DEV_MODE=true

# Trace Review - Langfuse target
# Standalone/default deployments use the bundled langfuse service.
# Override TRACE_REVIEW_LANGFUSE_HOST when this diagnostics service should read
# from a different Langfuse instance (for example, an Alliance-internal host).
TRACE_REVIEW_LANGFUSE_HOST=http://langfuse:3000
TRACE_REVIEW_LANGFUSE_PUBLIC_KEY=
TRACE_REVIEW_LANGFUSE_SECRET_KEY=

# Trace Review - Local Langfuse alternative (optional)
# Use source="local" in API calls to use this instead.
# Defaults to the same bundled langfuse service in the standalone stack.
TRACE_REVIEW_LANGFUSE_LOCAL_HOST=http://langfuse:3000
TRACE_REVIEW_LANGFUSE_LOCAL_PUBLIC_KEY=
TRACE_REVIEW_LANGFUSE_LOCAL_SECRET_KEY=

# Trace Review - Server config (usually don't need to change)
TRACE_REVIEW_BACKEND_HOST=0.0.0.0
TRACE_REVIEW_BACKEND_HOST_PORT=8001
TRACE_REVIEW_BACKEND_PORT=8001
TRACE_REVIEW_AI_CURATION_BACKEND_URL=http://backend:8000
TRACE_REVIEW_FRONTEND_URL=http://localhost:3001
TRACE_REVIEW_CACHE_TTL_HOURS=1

# Trace Review - Cognito (uses main COGNITO_* by default, override here if different)
#TRACE_REVIEW_COGNITO_REGION=us-east-1
#TRACE_REVIEW_COGNITO_USER_POOL_ID=
#TRACE_REVIEW_COGNITO_CLIENT_ID=
#TRACE_REVIEW_COGNITO_CLIENT_SECRET=
#TRACE_REVIEW_COGNITO_DOMAIN=
#TRACE_REVIEW_COGNITO_REDIRECT_URI=http://localhost:3001/api/auth/callback
