# =============================================================================
# GROUP DEFINITIONS (EXAMPLE)
# =============================================================================
# Copy this file to groups.yaml and customize it for your deployment.
#
# Key points:
# - AUTH_PROVIDER env var selects the active auth backend implementation
# - identity_provider.group_claim defines where group membership is stored in JWT
# - identity_provider.type/group_claim should align with the token claims your provider emits
# - provider_groups map external identity-provider groups to internal group IDs
# - legacy key `cognito_groups` is no longer supported (use `provider_groups`)
# =============================================================================

identity_provider:
  # Required identity provider metadata
  type: "oidc"

  # JWT claim used for group/role extraction
  # Common values:
  # - "cognito:groups"       (AWS Cognito)
  # - "groups"               (standard OIDC providers)
  # - "realm_access.roles"   (Keycloak deployments)
  group_claim: "groups"

groups:
  FB:
    name: "FlyBase"
    description: "Drosophila melanogaster curation team"
    species: "Drosophila melanogaster"
    taxon: "NCBITaxon:7227"
    provider_groups:
      - "flybase-curators"
      - "flybase-admins"

  WB:
    name: "WormBase"
    description: "C. elegans curation team"
    species: "Caenorhabditis elegans"
    taxon: "NCBITaxon:6239"
    provider_groups:
      - "wormbase-curators"
      - "wormbase-admins"

  # Add additional groups as needed:
  # MYORG:
  #   name: "My Organization"
  #   description: "Custom organization group"
  #   provider_groups:
  #     - "myorg-curators"
