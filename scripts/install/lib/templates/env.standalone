# Standalone deployment environment template.
# This file is the authoritative env template for standalone installs.

OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY
AUTH_PROVIDER=oidc
DEV_MODE=false

POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
REDIS_AUTH=CHANGE_ME_REDIS_AUTH
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/ai_curation

# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET
SALT=CHANGE_ME_SALT
ENCRYPTION_KEY=CHANGE_ME_64_CHAR_HEX

CLICKHOUSE_PASSWORD=CHANGE_ME_CLICKHOUSE_PASSWORD
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_ROOT_PASSWORD

LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-CHANGE_ME
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-CHANGE_ME
LANGFUSE_INIT_USER_PASSWORD=CHANGE_ME_LANGFUSE_INIT_USER_PASSWORD

# Must match init keys.
LANGFUSE_PUBLIC_KEY=${LANGFUSE_INIT_PROJECT_PUBLIC_KEY}
LANGFUSE_SECRET_KEY=${LANGFUSE_INIT_PROJECT_SECRET_KEY}

# Must equal MINIO_ROOT_PASSWORD.
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
LANGFUSE_S3_BATCH_EXPORT_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}

LLM_PROVIDER_STRICT_MODE=false
RUN_DB_BOOTSTRAP_ON_START=true
RUN_DB_MIGRATIONS_ON_START=true
HEALTH_CHECK_STRICT_MODE=true

LANGFUSE_DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/postgres
