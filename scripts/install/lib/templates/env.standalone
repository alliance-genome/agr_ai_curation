# Standalone deployment environment template.
# This file is the authoritative env template for standalone installs.

OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY
GROQ_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
AUTH_PROVIDER=oidc
DEV_MODE=false
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_GROUP_CLAIM=groups

POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
REDIS_AUTH=CHANGE_ME_REDIS_AUTH
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/ai_curation

# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET
SALT=CHANGE_ME_SALT
ENCRYPTION_KEY=CHANGE_ME_64_CHAR_HEX
LANGFUSE_LOCAL_NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET
LANGFUSE_LOCAL_SALT=CHANGE_ME_SALT
LANGFUSE_LOCAL_ENCRYPTION_KEY=CHANGE_ME_64_CHAR_HEX

CLICKHOUSE_PASSWORD=CHANGE_ME_CLICKHOUSE_PASSWORD
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_ROOT_PASSWORD

LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-CHANGE_ME
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-CHANGE_ME
LANGFUSE_INIT_USER_PASSWORD=CHANGE_ME_LANGFUSE_INIT_USER_PASSWORD

# Must match init keys.
LANGFUSE_PUBLIC_KEY=${LANGFUSE_INIT_PROJECT_PUBLIC_KEY}
LANGFUSE_SECRET_KEY=${LANGFUSE_INIT_PROJECT_SECRET_KEY}
LANGFUSE_LOCAL_PUBLIC_KEY=pk-lf-CHANGE_ME
LANGFUSE_LOCAL_SECRET_KEY=sk-lf-CHANGE_ME

# Must equal MINIO_ROOT_PASSWORD.
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
LANGFUSE_S3_BATCH_EXPORT_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}

LLM_PROVIDER_STRICT_MODE=false
RUN_DB_BOOTSTRAP_ON_START=true
RUN_DB_MIGRATIONS_ON_START=true
HEALTH_CHECK_STRICT_MODE=true

# Alliance standalone installs default to Bedrock reranking to match current behavior.
# Set local_transformers only when you will also run the local reranker container,
# or set none to keep retrieval order without post-retrieval reranking.
RERANK_PROVIDER=bedrock_cohere
BEDROCK_RERANK_MODEL_ARN=arn:aws:bedrock:us-east-1::foundation-model/cohere.rerank-v3-5:0
RERANKER_URL=http://reranker-transformers:8080

LANGFUSE_DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/postgres
LANGFUSE_LOCAL_DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/postgres

# Installer fills these with absolute paths under ~/.agr_ai_curation/.
# Leaving them blank preserves the compose-file defaults for manual runs.
AGR_RUNTIME_CONFIG_HOST_DIR=
AGR_REPO_CONFIG_HOST_DIR=
AGR_RUNTIME_PACKAGES_HOST_DIR=
AGR_RUNTIME_STATE_HOST_DIR=
PDF_STORAGE_HOST_DIR=
FILE_OUTPUT_STORAGE_HOST_DIR=
WEAVIATE_DATA_HOST_DIR=

# Manual baseline tags stay on latest. The installer rewrites them to a
# checkout-matched release tag or sha-<shortsha> when Git metadata is present.
BACKEND_IMAGE=public.ecr.aws/v4p5b7m9/agr-ai-curation-backend
BACKEND_IMAGE_TAG=latest
FRONTEND_IMAGE=public.ecr.aws/v4p5b7m9/agr-ai-curation-frontend
FRONTEND_IMAGE_TAG=latest
TRACE_REVIEW_BACKEND_IMAGE=public.ecr.aws/v4p5b7m9/agr-ai-curation-trace-review-backend
TRACE_REVIEW_BACKEND_IMAGE_TAG=latest
TRACE_REVIEW_URL=http://trace_review_backend:8001
TRACE_REVIEW_DEV_MODE=false
TRACE_REVIEW_LANGFUSE_HOST=http://langfuse:3000
TRACE_REVIEW_LANGFUSE_PUBLIC_KEY=${LANGFUSE_PUBLIC_KEY}
TRACE_REVIEW_LANGFUSE_SECRET_KEY=${LANGFUSE_SECRET_KEY}
TRACE_REVIEW_LANGFUSE_LOCAL_HOST=http://langfuse:3000
TRACE_REVIEW_LANGFUSE_LOCAL_PUBLIC_KEY=${LANGFUSE_LOCAL_PUBLIC_KEY}
TRACE_REVIEW_LANGFUSE_LOCAL_SECRET_KEY=${LANGFUSE_LOCAL_SECRET_KEY}
TRACE_REVIEW_BACKEND_HOST=0.0.0.0
TRACE_REVIEW_BACKEND_HOST_PORT=8001
TRACE_REVIEW_BACKEND_PORT=8001
TRACE_REVIEW_FRONTEND_URL=http://localhost:3001
TRACE_REVIEW_CACHE_TTL_HOURS=1
